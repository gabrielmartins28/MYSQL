--GROUP BY

--1)
SELECT cidade, COUNT(cidade) as qtd_alunos_cidade
From Alunos
GROUP BY cidade;

--2)
SELECT cidade, avg(idade) as Media_Idade
from Alunos
GROUP BY cidade;

--3)
SELECT id_curso, count(id_curso)
From Matriculas
GROUP BY id_curso;

--4)
SELECT id_curso, avg(nota) from Matriculas
GROUP BY id_curso;

--5)
SELECT id_curso, count(faltas) as quant_faltas
from Matriculas
GROUP BY id_curso;

--6)
SELECT id_curso, sum(faltas) as total_faltas
from Matriculas
GROUP BY id_curso;

--7)
SELECT id_curso, min(nota) as menorNota
from Matriculas
GROUP BY id_curso;

--8)
Select nome, sum(faltas) as faltas_aluno
from Alunos as a
join Matriculas as m
on a.id_aluno = m.id_aluno
GROUP BY nome;

--9)
SELECT nome, avg(nota) as media
from `Alunos` as a
JOIN Matriculas as m
on a.id_aluno = m.id_aluno
GROUP BY nome;

--10)
SELECT nome, count(idade) as faixa_etaria
from Alunos
GROUP BY nome;


--Questões Avançadas — HAVING e ORDER BY
--1)
SELECT cidade, COUNT(nome) as alunos
from Alunos
GROUP BY cidade
having alunos > 2;

--2)
SELECT id_curso, avg(nota) as media
from Matriculas
GROUP BY id_curso
HAVING media > 7;

--3)
SELECT id_curso, COUNT(id_matricula) as quantidade_matricula
from Matriculas
GROUP BY id_curso
HAVING quantidade_matricula > 2;

--4)
SELECT id_aluno, sum(faltas) as faltas
from Matriculas
GROUP BY id_aluno
HAVING faltas > 5;

--5) 
SELECT id_curso, min(nota) as menor_nota
from Matriculas
GROUP BY id_curso
HAVING menor_nota > 6;

--6)
SELECT nome_curso, carga_horaria
from Cursos
order by carga_horaria DESC;

--7)
SELECT nome, idade
FROM Alunos
ORDER BY idade DESC;

--8)
SELECT id_curso, avg(nota) as media
FROM Matriculas
GROUP BY id_curso
ORDER BY media DESC;

--9)
SELECT cidade, COUNT(id_aluno) as quantidade_aluno
from Alunos
GROUP BY cidade;

--10)
SELECT nome, avg(nota) as media
FROM Matriculas as m
JOIN Alunos as a
ON m.id_aluno = a.id_aluno
GROUP BY nome
HAVING media > 7
ORDER BY media DESC;

